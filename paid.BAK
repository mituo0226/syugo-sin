<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>有料鑑定 | ◆守護神占い◆</title>
  <style>
    :root { color-scheme: light dark; }
    body { margin: 0; font-family: system-ui, -apple-system, "Hiragino Kaku Gothic ProN", "Noto Sans JP", sans-serif; background: #0b0f17; color: #e6ecff; }
    .wrap { max-width: 860px; margin: 0 auto; padding: 24px; }
    header { display: flex; align-items: center; gap: 12px; }
    h1 { font-size: 1.5rem; margin: 12px 0 8px; }
    .sub { opacity: .7; font-size: .95rem; }
    .panel { background: #121829; border: 1px solid #1f2a44; border-radius: 14px; padding: 18px; box-shadow: 0 6px 24px rgba(0,0,0,.25); }
    .row { display: grid; gap: 12px; }
    .grid { display: grid; grid-template-columns: 1fr 2fr; gap: 12px; }
    label { font-size: .9rem; opacity: .9; }
    input[type="text"], textarea { width: 100%; padding: 10px 12px; border-radius: 10px; border: 1px solid #2a3657; background: #0d1220; color: #e6ecff; outline: none; }
    textarea { min-height: 120px; resize: vertical; }
    .btn { display: inline-block; padding: 12px 18px; border-radius: 999px; border: 1px solid #3751ff; background: #4b63ff; color: #fff; text-decoration: none; cursor: pointer; font-weight: 600; box-shadow: 0 6px 18px rgba(75,99,255,.35); transition: transform .06s ease; text-align: center; }
    .btn:active { transform: translateY(1px); }
    .muted { font-size: .9rem; opacity: .75; }
    #deepReading { white-space: pre-wrap; line-height: 1.9; font-size: 1.02rem; }
    .spacer { height: 16px; }

    #loadingScreen { position: fixed; inset: 0; background: rgba(7,10,18,.75); display: none; align-items: center; justify-content: center; z-index: 999; }
    .loader { width: 72px; height: 72px; border-radius: 50%; border: 6px solid #2a3657; border-top-color: #7f96ff; animation: spin .9s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg);} }

    @media (max-width: 680px) {
      .grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div id="loadingScreen"><div class="loader"></div></div>

  <div class="wrap">
    <header>
      <div>
        <h1>本鑑定（購入済み）</h1>
        <div class="sub">プレビューと同じ文頭（teaser）から、そのまま“続き”が展開されます。</div>
      </div>
    </header>

    <div class="spacer"></div>

    <section class="panel">
      <form id="questionForm" class="row" autocomplete="off">
        <div class="grid">
          <div><label for="dob">生年月日</label></div>
          <div><div id="dob" class="muted">-</div></div>

          <div><label for="category">相談ジャンル</label></div>
          <div><input id="category" name="category" type="text" placeholder="例）恋愛 / 仕事 / 金運 など"></div>

          <div><label for="question">ご相談内容</label></div>
          <div><textarea id="question" name="question" placeholder="例）最近の距離感に悩んでいます。今後どう向き合えば良いでしょうか。"></textarea></div>
        </div>
        <div>
          <button type="submit" class="btn" id="submitBtn">本鑑定の全文を表示する</button>
        </div>
        <div class="muted">※ 先に見えていたモザイクの文頭（teaser）と完全に同じ一文で始まり、その“続き”が展開されます。</div>
      </form>
    </section>

    <div class="spacer"></div>

    <section class="panel">
      <h2 style="margin:0 0 8px;font-size:1.1rem;">鑑定結果</h2>
      <div id="deepReading" class="muted">（ここに本鑑定の全文が表示されます）</div>
    </section>

    <div class="spacer"></div>
  </div>

  <script>
  const API_URL = 'https://syugo-sin-kantei-api.mituo0226.workers.dev/consult';
  const SKEY = 'kanteiContext';
  function loadSS(){ try{ return JSON.parse(sessionStorage.getItem(SKEY) || '{}'); }catch{ return {}; } }
  function saveSS(obj){ try{ sessionStorage.setItem(SKEY, JSON.stringify(obj)); }catch{} }

  const qs = new URLSearchParams(location.search);
  const ctx = {
    year:  Number(qs.get('year'))  || loadSS().year  || 0,
    month: Number(qs.get('month')) || loadSS().month || 0,
    day:   Number(qs.get('day'))   || loadSS().day   || 0,
    category: (qs.get('category') || loadSS().category || '').toString(),
    question: (qs.get('question') || loadSS().question || '').toString()
  };

  // DOB表示
  const dobEl = document.getElementById('dob');
  if (ctx.year && ctx.month && ctx.day) {
    dobEl.textContent = `${ctx.year}年${ctx.month}月${ctx.day}日 生まれ`;
  } else {
    dobEl.textContent = '生年月日が未設定です（前のページから引き継いでください）';
  }

  // 入力初期値
  document.getElementById('category').value = ctx.category;
  document.getElementById('question').value = ctx.question;

  const form = document.getElementById('questionForm');
  const deepReading = document.getElementById('deepReading');
  const loading = document.getElementById('loadingScreen');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const category = document.getElementById('category').value.trim();
    const question = document.getElementById('question').value.trim();

    if (!ctx.year || !ctx.month || !ctx.day) {
      alert('生年月日（年・月・日）が不足しています。戻って入力してください。');
      return;
    }
    if (!category || !question) {
      alert('相談ジャンルと内容を入力してください。');
      return;
    }

    saveSS({ ...ctx, category, question });

    loading.style.display = 'flex';
    deepReading.classList.add('muted');
    deepReading.textContent = '鑑定を生成しています…';

    try {
      const res = await fetch(API_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          mode: 'full',
          year: ctx.year,
          month: ctx.month,
          day: ctx.day,
          text: `【相談ジャンル】${category}\n【相談内容】${question}`
        })
      });

      const data = await res.json().catch(() => ({}));
      loading.style.display = 'none';

      if (!res.ok) {
        deepReading.textContent = `エラー: ${data?.error || '取得に失敗しました'}`;
        return;
      }

      deepReading.textContent = data.full_text || '(本文を取得できませんでした)';
      deepReading.classList.remove('muted');
      form.style.display = 'none';
      window.scrollTo({ top: 0, behavior: 'smooth' });
    } catch (err) {
      loading.style.display = 'none';
      deepReading.textContent = `通信エラー: ${err?.message || err}`;
    }
  });

  // 確認・運用向け：?autofetch=1 なら自動送信
  if (qs.get('autofetch') === '1' && ctx.year && ctx.month && ctx.day && (ctx.category || ctx.question)) {
    if (!document.getElementById('category').value) document.getElementById('category').value = ctx.category || '総合';
    if (!document.getElementById('question').value) document.getElementById('question').value = ctx.question || '最近の運気と具体行動を教えてください。';
    setTimeout(() => document.getElementById('submitBtn').click(), 300);
  }
  </script>
</body>
</html>
